classDiagram
    class LibraryRepository {
        -List~Item~ items
        +addItem(Item item)
        +removeItem(Item item)
        +updateItem(Item item)
        +findItem(String name) Item
        +listItems() List~Item~
        +lendItem(Person person, Item item, int days)
        +returnItem(Person person, Item item)
    }

    class Person {
        <<abstract>>
        -String name
        -String cpf
        -String id
        +read(Item item)
        +consume(Item item)
    }

    class Librarian {
        +addItemToLibrary(Item item)
    }

    class Student {
        +int maxBorrowDays
        +borrowItem(Item item)
    }

    class Researcher {
        +int maxBorrowDays
        +borrowItem(Item item)
        +publishPaper(Paper paper)
    }

    class Teacher {
        +int maxBorrowDays
        +borrowItem(Item item)
    }

    class Author {
        +publishBook(Book book)
    }

    class Item {
        <<abstract>>
        -String name
        -int amount
        +getName() String
        +getAmount() int
    }

    class Book {
        -Author author
        +getAuthor() Author
    }

    class Paper {
        -Researcher researcher
        +getResearcher() Researcher
    }

    Person <|-- Librarian
    Person <|-- Student
    Person <|-- Researcher
    Person <|-- Teacher
    Person <|-- Author

    Item <|-- Book
    Item <|-- Paper

    Book "1" --> "1" Author : has
    Paper "1" --> "1" Researcher : has

    LibraryRepository "1" o-- "*" Item : manages
    LibraryRepository ..> Person : lends to
