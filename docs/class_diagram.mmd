classDiagram
direction LR

class Status{
    <<enumeration>>
    BORROWED
    AVAILABLE
    UNAVAILABLE
}

class Item{
    <<abstract>>
    -Status status
    +uint32_t id
    +string name
    +accessItem()*
    +getStatus() Status
    +setStatus(Status)
    +print()
}

class PublicItem{
    -string DisplayArea
    +getDisplayArea() string
    +setDisplayArea(string)
    +accessItem()
}

class LoanableItem{
    +uint32_t responsibleId
    +time_t borrowedAt
    +time_t dueDate
    +isBorrowed() bool
    +daysRemaining() int
    +accessItem()
}

class ExhibitionItem{
    +setDisplayArea(string)
    +accessItem()
}

class RestrictedItem{
    +Visit AccessAppointments[5][3]
    +setStatus(Status)
    +accessItem()
    +getAvailableAppointments()
    +ScheduleVisit(int,int,string,uint32_t)
}

Item <|-- PublicItem
PublicItem <|-- LoanableItem
PublicItem <|-- ExhibitionItem
Item <|-- RestrictedItem

Item --> Status
